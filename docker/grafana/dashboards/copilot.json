{
  "title": "CoPilot API",
  "uid": "copilot-api",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(copilot_http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(copilot_http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / sum(rate(copilot_http_server_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(copilot_http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(copilot_http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(copilot_http_server_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": ".NET GC Heap Size",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "copilot_process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "Gen {{generation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "title": "Thread Pool — Active Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "copilot_process_runtime_dotnet_thread_pool_threads_count",
          "legendFormat": "threads"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "copilot_process_runtime_dotnet_thread_pool_queue_length",
          "legendFormat": "queue length"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Todo Items Created",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(copilot_todoitems_created_total)",
          "legendFormat": "created"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 7,
      "title": "Todo Items Completed",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(copilot_todoitems_completed_total)",
          "legendFormat": "completed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 8,
      "title": "Todo Lists Created",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(copilot_todolists_created_total)",
          "legendFormat": "lists"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": 0 }] } } }
    }
  ]
}
